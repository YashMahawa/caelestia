#!/usr/bin/env python3
"""Event-driven activity bridge for Caelestia's Agents dashboard."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import pathlib
import re
import select
import sqlite3
import subprocess
import sys
import tempfile
import time

HOME = pathlib.Path.home()
CODEX = HOME / ".codex"
DB = CODEX / "state_5.sqlite"
STATE_DIR = HOME / ".local/state/caelestia"
STATE = STATE_DIR / "agents.json"
NOTIFY_STATE = STATE_DIR / "agents-notified.json"
WATCH = (CODEX / "sessions", CODEX, HOME / ".config/Antigravity/logs")


def iso_ms(value: str | None) -> int:
    if not value:
        return 0
    try:
        return int(dt.datetime.fromisoformat(value.replace("Z", "+00:00")).timestamp() * 1000)
    except ValueError:
        return 0


def clean(text: str, limit: int = 150) -> str:
    text = re.sub(r"<image[^>]*>.*?</image>", "", text or "", flags=re.S)
    text = re.sub(r"\s+", " ", text).strip()
    return text if len(text) <= limit else text[: limit - 1].rstrip() + "…"


def tail_json(path: pathlib.Path, limit: int = 1024 * 1024) -> list[dict]:
    try:
        with path.open("rb") as stream:
            size = stream.seek(0, 2)
            stream.seek(max(0, size - limit))
            if size > limit:
                stream.readline()
            raw = stream.read()
    except OSError:
        return []
    events = []
    for line in raw.splitlines():
        try:
            events.append(json.loads(line))
        except (ValueError, UnicodeDecodeError):
            pass
    return events


def codex_processes() -> tuple[set[str], bool]:
    thread_ids: set[str] = set()
    desktop = False
    try:
        output = subprocess.check_output(["pgrep", "-af", "codex|ChatGPT"], text=True)
    except subprocess.CalledProcessError:
        return thread_ids, desktop
    for line in output.splitlines():
        if "codex-desktop" in line or "/codex-app/electron" in line:
            desktop = True
        match = re.search(r"\bcodex(?:\s+--?\S+(?:=\S+)?)*\s+resume\s+([0-9a-f-]{36})", line)
        if match:
            thread_ids.add(match.group(1))
    return thread_ids, desktop


def grok_turn_active() -> bool:
    # Grok deliberately holds an idle-inhibitor for the complete turn,
    # including low-CPU tool calls. This is a stable lifecycle signal.
    for entry in pathlib.Path("/proc").iterdir():
        if not entry.name.isdigit():
            continue
        try:
            command = (entry / "cmdline").read_bytes().replace(b"\0", b" ").decode(errors="ignore")
        except OSError:
            continue
        if "systemd-inhibit" in command and "--who=grok" in command and "agent turn in progress" in command:
            return True
    return False


def detail_for(name: str) -> str:
    return {
        "exec": "Running a system task",
        "apply_patch": "Editing files",
        "browser-use": "Using the browser",
        "chrome": "Working in Chrome",
        "request_user_input": "Waiting for your answer",
    }.get(name, "Using " + name.replace("_", " "))


def parse_codex(row: sqlite3.Row, cli_threads: set[str], now: int) -> dict:
    events = tail_json(pathlib.Path(row["rollout_path"]))
    last_user = -1
    last_final = -1
    last_update = int(row["updated_at_ms"] or 0)
    started = last_update
    title = clean(row["preview"] or row["title"] or "Codex task", 96)
    detail = "Thinking"
    waiting = False
    error = False
    for index, event in enumerate(events):
        payload = event.get("payload") or {}
        kind = payload.get("type")
        stamp = iso_ms(event.get("timestamp"))
        if stamp:
            last_update = max(last_update, stamp)
        if kind == "user_message" or (kind == "message" and payload.get("role") == "user"):
            message = payload.get("message")
            if not message:
                content = payload.get("content") or []
                message = content[0].get("text") or content[0].get("input_text") if content else ""
            if clean(message):
                title = clean(message, 96)
            last_user = index
            started = stamp or last_update
            waiting = False
        elif kind == "agent_message" or (kind == "message" and payload.get("role") == "assistant"):
            phase = payload.get("phase")
            message = payload.get("message")
            if not message:
                content = payload.get("content") or []
                message = content[0].get("text") if content else ""
            if phase == "final":
                last_final = index
                detail = clean(message, 110) or "Completed"
            elif clean(message):
                detail = clean(message, 110)
        elif kind == "custom_tool_call":
            tool = payload.get("name") or "a tool"
            detail = detail_for(tool)
            waiting = tool == "request_user_input" and payload.get("status") != "completed"
        elif kind in {"turn_aborted", "error", "stream_error"}:
            error = True
            detail = clean(payload.get("message") or payload.get("error") or "Task failed", 110)

    if error and now - last_update < 12 * 60 * 1000:
        status = "error"
    elif waiting:
        status = "waiting"
    elif last_final > last_user >= 0:
        status = "completed"
    elif now - last_update > 12 * 60 * 1000:
        status = "paused"
        detail = "Paused — open to continue"
    else:
        status = "working"

    surface = "Codex CLI" if row["id"] in cli_threads else "Codex"
    return {
        "id": "codex:" + row["id"],
        "threadId": row["id"],
        "agent": surface,
        "icon": "terminal" if surface.endswith("CLI") else "smart_toy",
        "status": status,
        "title": title,
        "detail": detail,
        "cwd": row["cwd"] or "",
        "startedAtMs": started,
        "updatedAtMs": last_update,
        "actionable": waiting,
        "actionLabel": "Review" if waiting else "",
    }


def window_agents(now: int) -> list[dict]:
    try:
        clients = json.loads(subprocess.check_output(["hyprctl", "clients", "-j"], text=True))
    except (OSError, subprocess.CalledProcessError, ValueError):
        return []
    found: dict[str, dict] = {}
    for client in clients:
        blob = " ".join(str(client.get(key, "")) for key in ("class", "initialClass", "title", "initialTitle")).lower()
        attention = any(word in blob for word in ("approve", "approval", "review plan", "accept or reject"))
        active_word = any(word in blob for word in ("responding", "working", "thinking", "running"))
        if "antigravity" in blob and (attention or active_word):
            found["antigravity"] = {
                "id": "antigravity:app", "agent": "Antigravity", "icon": "auto_awesome",
                "status": "waiting" if attention else "working",
                "title": clean(client.get("title") or "Antigravity", 96),
                "detail": "Plan or tool approval needed" if attention else "Working",
                "updatedAtMs": now, "startedAtMs": now,
                "actionable": attention, "actionLabel": "Review" if attention else "",
            }
        if re.search(r"\bgrok\b", blob):
            busy = active_word or grok_turn_active()
            if not busy:
                continue
            found["grok"] = {
                "id": "grok:app", "agent": "Grok", "icon": "bolt",
                "status": "working", "title": clean(client.get("title") or "Grok", 96),
                "detail": "Responding", "updatedAtMs": now, "startedAtMs": now,
                "actionable": False, "actionLabel": "",
            }
    return list(found.values())


def collect() -> dict:
    now = int(time.time() * 1000)
    cli_threads, _ = codex_processes()
    tasks: list[dict] = []
    if DB.exists():
        try:
            connection = sqlite3.connect(f"file:{DB}?mode=ro", uri=True, timeout=1)
            connection.row_factory = sqlite3.Row
            rows = connection.execute(
                "select id, rollout_path, title, preview, cwd, updated_at_ms from threads "
                "where archived=0 and rollout_path <> '' order by updated_at_ms desc limit 8"
            ).fetchall()
            connection.close()
            tasks.extend(parse_codex(row, cli_threads, now) for row in rows)
        except sqlite3.Error:
            pass
    window_tasks = window_agents(now)
    try:
        previous = {item["id"]: item for item in json.loads(STATE.read_text()).get("tasks", [])}
    except (OSError, ValueError):
        previous = {}
    for task in window_tasks:
        old = previous.get(task["id"])
        if old and old.get("status") == task["status"] and old.get("title") == task["title"]:
            task["updatedAtMs"] = old.get("updatedAtMs", now)
            task["startedAtMs"] = old.get("startedAtMs", now)
    tasks.extend(window_tasks)
    notifications_queue = [task for task in tasks if task["status"] in {"waiting", "completed", "error"}]
    tasks = [task for task in tasks if task["status"] in {"waiting", "working"}]
    tasks.sort(key=lambda item: (item["status"] != "waiting", -item["updatedAtMs"]))
    return {"version": 2, "updatedAtMs": now, "tasks": tasks[:8], "notifications": notifications_queue[:8]}


def atomic_write(path: pathlib.Path, value: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temporary = tempfile.mkstemp(prefix=path.name + ".", dir=path.parent)
    try:
        with os.fdopen(fd, "w") as stream:
            json.dump(value, stream, separators=(",", ":"))
            stream.write("\n")
        os.replace(temporary, path)
    finally:
        try:
            os.unlink(temporary)
        except FileNotFoundError:
            pass


def notifications(state: dict) -> None:
    previous: dict[str, str] = {}
    try:
        previous = json.loads(NOTIFY_STATE.read_text())
    except (OSError, ValueError):
        pass
    current = dict(previous)
    for task in state.get("notifications", state["tasks"]):
        status = task["status"]
        marker = status + ":" + str(task["updatedAtMs"])
        is_fresh = state["updatedAtMs"] - task["updatedAtMs"] < 5 * 60 * 1000
        if is_fresh and status in {"waiting", "completed", "error"} and previous.get(task["id"]) != marker:
            urgency = "critical" if status in {"waiting", "error"} else "normal"
            heading = f'{task["agent"]} · {status.capitalize()}'
            subprocess.Popen(
                ["notify-send", "-a", task["agent"], "-u", urgency, "-i", "applications-development", heading, task["title"]],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            current[task["id"]] = marker
    atomic_write(NOTIFY_STATE, current)


def refresh() -> None:
    state = collect()
    atomic_write(STATE, state)
    notifications(state)


def daemon() -> int:
    refresh()
    paths = [str(path) for path in WATCH if path.exists()]
    command = ["inotifywait", "-m", "-q", "-r", "-e", "close_write,create,move,delete", "--format", "%w%f", *paths]
    watcher = subprocess.Popen(command, stdout=subprocess.PIPE, text=True, bufsize=1)
    assert watcher.stdout is not None
    poller = select.poll()
    poller.register(watcher.stdout, select.POLLIN)
    last_grok_active = grok_turn_active()
    while watcher.poll() is None:
        events = poller.poll(2000)
        if events:
            watcher.stdout.readline()
            time.sleep(0.08)
            while poller.poll(0):
                watcher.stdout.readline()
            refresh()
        grok_active = grok_turn_active()
        if grok_active != last_grok_active:
            last_grok_active = grok_active
            refresh()
    return watcher.returncode or 1


def focus(agent: str, thread: str = "") -> int:
    if agent.startswith("Codex"):
        target = "class:^(codex-desktop)$" if agent == "Codex" else "title:.*codex.*"
    elif agent == "Antigravity":
        target = "class:.*[Aa]ntigravity.*"
    else:
        target = "title:.*[Gg]rok.*"
    return subprocess.call(["hyprctl", "dispatch", "focuswindow", target], stdout=subprocess.DEVNULL)


def main() -> int:
    parser = argparse.ArgumentParser()
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("daemon")
    sub.add_parser("refresh")
    focus_parser = sub.add_parser("focus")
    focus_parser.add_argument("agent")
    focus_parser.add_argument("thread", nargs="?", default="")
    args = parser.parse_args()
    if args.command in (None, "daemon"):
        return daemon()
    if args.command == "refresh":
        refresh()
        return 0
    return focus(args.agent, args.thread)


if __name__ == "__main__":
    raise SystemExit(main())
