#!/usr/bin/env python3
"""Caelestia Link helper: connectivity, sharing, and privacy controls."""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

CONFIG = Path.home() / ".config/caelestia/continuity.json"
DEFAULTS = {
    "deviceId": "2d66b7a5cb214ae4be66b7b8f2ff46bb",
    "deviceName": "V2240",
    "autoClipboardSync": False,
    "callsEnabled": True,
    "notificationsEnabled": True,
}


def run(*args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(args, text=True, capture_output=True, timeout=30, check=False)


def device() -> str | None:
    result = run("kdeconnect-cli", "--list-available", "--id-only")
    available = result.stdout.split() if result.returncode == 0 else []
    preferred = str(config().get("deviceId", ""))
    return preferred if preferred in available else (available[0] if available else None)


def config() -> dict:
    value = dict(DEFAULTS)
    if CONFIG.exists():
        value.update(json.loads(CONFIG.read_text(encoding="utf-8")))
    value.pop("syncRules", None)
    return value


def save_config(value: dict) -> None:
    CONFIG.parent.mkdir(parents=True, exist_ok=True)
    temporary = CONFIG.with_suffix(".tmp")
    temporary.write_text(json.dumps(value, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    temporary.replace(CONFIG)


def status() -> int:
    current = device()
    print(json.dumps({"reachable": current is not None, "deviceId": current, **config()}, ensure_ascii=False))
    return 0 if current else 2


def share(paths: list[str]) -> int:
    return subprocess.call(["caelestia-clipboard", "send-path", *paths])


def auto_clipboard(mode: str) -> int:
    settings = config()
    enabled = bool(settings.get("autoClipboardSync", False))
    enabled = not enabled if mode == "toggle" else mode == "on"
    current = device()
    if current is None:
        print("Caelestia Link phone is not reachable", file=sys.stderr)
        return 2
    result = run(
        "qdbus6", "org.kde.kdeconnect", f"/modules/kdeconnect/devices/{current}",
        "org.kde.kdeconnect.device.setPluginEnabled", "kdeconnect_clipboard",
        "true" if enabled else "false",
    )
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        return result.returncode
    settings["autoClipboardSync"] = enabled
    save_config(settings)
    print("on" if enabled else "off")
    return 0


def privacy_toggle(setting: str, plugin: str, mode: str) -> int:
    settings = config()
    enabled = bool(settings.get(setting, True))
    enabled = not enabled if mode == "toggle" else mode == "on"
    current = device()
    if current is None:
        print("Caelestia Link phone is not reachable", file=sys.stderr)
        return 2
    result = run(
        "qdbus6", "org.kde.kdeconnect", f"/modules/kdeconnect/devices/{current}",
        "org.kde.kdeconnect.device.setPluginEnabled", plugin,
        "true" if enabled else "false",
    )
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        return result.returncode
    settings[setting] = enabled
    save_config(settings)
    print("on" if enabled else "off")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    commands = parser.add_subparsers(dest="command", required=True)
    commands.add_parser("status")
    commands.add_parser("ring")
    auto = commands.add_parser("auto-clipboard")
    auto.add_argument("mode", choices=("on", "off", "toggle"))
    calls = commands.add_parser("calls")
    calls.add_argument("mode", choices=("on", "off", "toggle"))
    notifications = commands.add_parser("notifications")
    notifications.add_argument("mode", choices=("on", "off", "toggle"))
    send = commands.add_parser("send")
    send.add_argument("paths", nargs="+")
    args = parser.parse_args()
    if args.command == "status":
        return status()
    if args.command == "send":
        return share(args.paths)
    if args.command == "ring":
        current = device()
        return subprocess.call(["kdeconnect-cli", "-d", current, "--ring"]) if current else 2
    if args.command == "auto-clipboard":
        return auto_clipboard(args.mode)
    if args.command == "calls":
        return privacy_toggle("callsEnabled", "kdeconnect_telephony", args.mode)
    if args.command == "notifications":
        return privacy_toggle("notificationsEnabled", "kdeconnect_notifications", args.mode)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
