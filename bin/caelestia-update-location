#!/usr/bin/env python3
import sys
import os
import json

def main():
    if len(sys.argv) < 2:
        print("Usage: caelestia-update-location <latitude,longitude>")
        sys.exit(1)

    coords = sys.argv[1].strip()
    config_path = os.path.expanduser("~/.config/caelestia/shell.json")

    if not os.path.exists(config_path):
        print(f"Error: Config file not found at {config_path}")
        sys.exit(1)

    try:
        with open(config_path, "r") as f:
            config = json.load(f)
    except Exception as e:
        print(f"Error reading JSON: {e}")
        sys.exit(1)

    # Update the weatherLocation inside services
    if "services" not in config:
        config["services"] = {}

    config["services"]["weatherLocation"] = coords

    try:
        with open(config_path, "w") as f:
            json.dump(config, f, indent=4)
        print(f"Successfully updated weatherLocation to: {coords}")
    except Exception as e:
        print(f"Error writing JSON: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
