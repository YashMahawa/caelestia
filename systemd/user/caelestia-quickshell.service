[Unit]
Description=Caelestia Quickshell
After=graphical-session.target hyprland-session-anchor.service
Wants=hyprland-session-anchor.service
PartOf=graphical-session.target

[Service]
Type=simple
ExecStartPre=/usr/bin/sleep 3
ExecStartPre=/home/yash/.local/bin/caelestia-qs-clean-runtime
ExecStart=/usr/sbin/qs -c caelestia -n --log-rules *.debug=false
ExecStop=/usr/sbin/qs kill -c caelestia
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
